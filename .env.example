PORT=3000

# Standard MongoDB Atlas connection string (mongodb+srv://)
# Use this first. If you get a "querySrv ECONNREFUSED" error, your network
# likely blocks SRV-type DNS lookups — switch to the non-SRV format below instead.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Cluster0

# Non-SRV fallback (use if the srv:// string above fails to connect):
# 1. Run: nslookup -type=SRV _mongodb._tcp.<cluster-url>   -> gives you the shard hostnames
# 2. Run: nslookup -type=TXT <cluster-url>                 -> gives you the replicaSet name
# MONGODB_URI=mongodb://<username>:<password>@<shard-0>:27017,<shard-1>:27017,<shard-2>:27017/?ssl=true&replicaSet=<replica-set-name>&authSource=admin&retryWrites=true&w=majority&appName=Cluster0
